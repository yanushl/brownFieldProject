{
  "version": "1.0.0",
  "description": "SF AI Dev Framework skills registry — skill discovery, orchestration, and agent mapping",

  "guardrails": {
    "dangerous_dml": {
      "patterns": ["DELETE FROM \\w+ (;|$)", "UPDATE \\w+ SET .* (?<!WHERE.*)$"],
      "severity": "CRITICAL",
      "action": "block",
      "message": "Destructive DML without WHERE clause detected"
    },
    "unbounded_soql": {
      "patterns": ["SELECT .* FROM \\w+ (?!.*LIMIT)"],
      "severity": "HIGH",
      "action": "warn",
      "message": "Unbounded SOQL query — consider adding LIMIT"
    },
    "hardcoded_credentials": {
      "patterns": ["(password|api_key|secret|token)\\s*=\\s*['\"][^'\"]+['\"]"],
      "severity": "CRITICAL",
      "action": "block",
      "message": "Hardcoded credentials detected — use Named Credentials or Custom Metadata"
    },
    "missing_sharing_keyword": {
      "patterns": ["public class \\w+(?! (with|without|inherited) sharing)"],
      "severity": "MEDIUM",
      "action": "warn",
      "message": "Consider adding explicit sharing keyword (with sharing recommended)"
    },
    "hardcoded_salesforce_ids": {
      "patterns": ["['\"][a-zA-Z0-9]{15}['\"]|['\"][a-zA-Z0-9]{18}['\"]"],
      "severity": "MEDIUM",
      "action": "warn",
      "message": "Hardcoded Salesforce ID detected — consider using Custom Metadata"
    }
  },

  "skills": {
    "sf-apex": {
      "path": ".claude/skills/sf-apex/SKILL.md",
      "description": "Apex code generation, review, patterns, and best practices",
      "keywords": ["apex", "trigger", "class", "batch", "queueable", "schedulable", "invocable", "selector", "service layer", "domain"],
      "filePatterns": ["\\.cls$", "\\.trigger$"],
      "usedByAgents": ["dev-agent"],
      "orchestration": {
        "next_steps": ["sf-testing", "sf-deploy"],
        "commonly_with": ["sf-lwc", "sf-metadata"]
      }
    },

    "sf-testing": {
      "path": ".claude/skills/sf-testing/SKILL.md",
      "description": "Apex test writing, execution, coverage analysis, mocking, factories",
      "keywords": ["test", "coverage", "assert", "mock", "unit test", "test factory", "test setup"],
      "filePatterns": [".*Test\\.cls$", ".*_Test\\.cls$"],
      "usedByAgents": ["dev-agent"],
      "orchestration": {
        "prerequisites": ["sf-apex"],
        "next_steps": ["sf-deploy"]
      }
    },

    "sf-soql": {
      "path": ".claude/skills/sf-soql/SKILL.md",
      "description": "SOQL query generation, optimization, security patterns",
      "keywords": ["soql", "query", "select", "where", "aggregate", "subquery", "relationship query"],
      "filePatterns": ["\\.cls$"],
      "usedByAgents": ["dev-agent"],
      "orchestration": {
        "commonly_with": ["sf-apex"]
      }
    },

    "sf-lwc": {
      "path": ".claude/skills/sf-lwc/SKILL.md",
      "description": "Lightning Web Components — structure, wire service, events, SLDS",
      "keywords": ["lwc", "lightning web component", "wire", "apex wire", "slds", "html template", "jest", "lms"],
      "filePatterns": ["lwc/.*\\.(js|html|css)$", "\\.js-meta\\.xml$"],
      "usedByAgents": ["dev-agent"],
      "orchestration": {
        "prerequisites": ["sf-apex"],
        "next_steps": ["sf-deploy"]
      }
    },

    "sf-deploy": {
      "path": ".claude/skills/sf-deploy/SKILL.md",
