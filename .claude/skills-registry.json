  "agents": {
    "dev-agent": {
      "path": ".claude/agents/dev-agent.md",
      "description": "Write code + tests + deploy + verify (one context for full write-test-deploy cycle)",
      "model": "sonnet",
      "skills": ["sf-apex", "sf-lwc", "sf-testing", "sf-soql", "sf-metadata", "sf-deploy"],
      "tools": ["mcp__chrome-devtools"],
      "input": "Solution JSON + project context",
      "output": "Implementation files + deployment status + test results + coverage"
    },
    "deploy-agent": {
      "path": ".claude/agents/deploy-agent.md",
      "description": "Deploy to org + handle errors + retry (procedural, isolated)",
      "model": "haiku",
      "skills": ["sf-deploy"],
      "input": "Files to deploy",
      "output": "Deployment status + errors if any"
    },
    "browser-verify-agent": {
      "path": ".claude/agents/browser-verify-agent.md",
      "description": "Browser verification of deployed implementations using Chrome DevTools MCP",
      "model": "sonnet",
      "skills": [],
      "tools": ["mcp__chrome-devtools"],
      "input": "Implementation context (dev-agent output or user description) + org URL",
      "output": "Verification results (pass/partial/fail) + screenshots + console errors"
    },
    "pr-agent": {
      "path": ".claude/agents/pr-agent.md",
      "description": "Create branch + commit + push + PR (isolated, reads git diff fresh)",
      "model": "sonnet",
      "skills": [],
      "input": "Solution summary + files changed + test results + Jira reference",
      "output": "PR URL"
    }
  }
